LEAGUE=nhl
TEAM=Colorado Avalanche
EMAIL_TO=user@example.com
EMAIL_FROM=bot@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bot@example.com
SMTP_PASSWORD=app_password_here
POLL_INTERVAL_SECONDS=14400

# Optional Lambda-prefixed variants (used first when running in Lambda)
LAMBDA_LEAGUE=nhl
LAMBDA_TEAM=Colorado Avalanche
LAMBDA_EMAIL_TO=user@example.com
LAMBDA_EMAIL_FROM=bot@example.com
LAMBDA_SMTP_HOST=smtp.gmail.com
LAMBDA_SMTP_PORT=587
LAMBDA_SMTP_USER=bot@example.com
LAMBDA_SMTP_PASSWORD=app_password_here
LAMBDA_POLL_INTERVAL_SECONDS=14400

